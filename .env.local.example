# Copy to .env.local and fill in.
#
# ── DATABASE (Drizzle) ────────────────────────────────────────────────────
# Local-first (Docker Postgres):
#   docker run -d --name updev-pg -e POSTGRES_USER=updev -e POSTGRES_PASSWORD=updev \
#     -e POSTGRES_DB=updev -p 5433:5432 postgres:16
DATABASE_URL=postgres://updev:updev@localhost:5433/updev
#
# Supabase: use the "Connection string" from Project Settings → Database.
# For drizzle-kit push + seed use the *direct* connection (port 5432).
# Example: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
#
# ── AUTH (Supabase) ───────────────────────────────────────────────────────
# From Project Settings → API. When both are set, the login gate turns on.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
