# Copy to .env.local and fill in.
#
# Local-first (Docker Postgres):
#   docker run -d --name updev-pg -e POSTGRES_USER=updev -e POSTGRES_PASSWORD=updev \
#     -e POSTGRES_DB=updev -p 5433:5432 postgres:16
DATABASE_URL=postgres://updev:updev@localhost:5433/updev

# Supabase (later — M6). When migrating, point DATABASE_URL at the Supabase
# connection string (Transaction mode, port 6543) and add:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
